# Environment example (additional keys for Razorpay)

# Razorpay sandbox keys (set these when testing)
RAZORPAY_KEY_ID=your_test_key_id
RAZORPAY_KEY_SECRET=your_test_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Real money mode (toggle)
ENABLE_REAL_MONEY=true

# Safety & limits
MANUAL_REVIEW_THRESHOLD=250000
MAX_PAYOUT_PER_BET=1000000
HOUSE_MIN_RESERVE=100000
