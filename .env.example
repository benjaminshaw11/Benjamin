# Environment example

# Database
DATABASE_URL=postgres://user:pass@localhost:5432/yourdb

# JWT
JWT_SECRET=your_jwt_secret

# Seed encryption (optional - hex 32 bytes)
SEED_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Rig mode (dev only)
# RIG_MODE=force_house_win
# NODE_ENV must not be production to allow rigging

# Payout / safety limits
MAX_MULTIPLIER=2.0
MAX_PAYOUT_PER_BET=1000000
MANUAL_REVIEW_THRESHOLD=250000
HOUSE_MIN_RESERVE=100000

NODE_ENV=development
